{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "process",
      "command": "D:\\DevEnv\\cmake-4.2.3-windows-x86_64\\bin\\cmake.exe",
      "args": [
        "--build",
        "--preset",
        "build-debug"
      ],
      "options": {
        "cwd": "D:/Project/MSPM0G3507_VSCODE"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "detail": "按 build-debug 预设编译项目"
    },
    {
      "label": "SysConfig",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "D:/Project/MSPM0G3507_VSCODE/.vscode/scripts/open-sysconfig.ps1",
        "-WorkspaceFolder",
        "D:/Project/MSPM0G3507_VSCODE"
      ],
      "group": "build",
      "problemMatcher": [],
      "detail": "打开 TI SysConfig 配置工具"
    },
    {
      "label": "Flash",
      "type": "shell",
      "command": "D:\\DevEnv\\OpenOCD-20260121-0.12.0\\bin\\openocd.exe",
      "args": [
        "-s", "D:\\DevEnv\\OpenOCD-20260121-0.12.0\\share\\openocd\\scripts",
        "-f", "interface/cmsis-dap.cfg",
        "-c", "transport select swd; adapter speed 8000",
        "-f", "target/ti/mspm0.cfg",
        "-c", "program D:/Project/MSPM0G3507_VSCODE/build/MSPM0.elf verify reset exit"
      ],
      "group": "build",
      "problemMatcher": [],
      "detail": "烧录固件到 MCU（不进 Debug）"
    }
  ]
}
